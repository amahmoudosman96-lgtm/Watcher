# Watcher — environment configuration (placeholders)
#
# Copy to `.env` and fill in. The `<...>` values are the items tagged NEEDS INPUT
# in docs/build-spec-addendum.md §17. In production these are per-tenant and
# encrypted at rest (§3); this file is for local/dev and non-secret config.

# ─────────────────────────────────────────────────────────────────────────────
# Meta WhatsApp Business Cloud API — ingestion (§5) — NEEDS INPUT
# Source: Meta App dashboard → WhatsApp → API setup
# ─────────────────────────────────────────────────────────────────────────────
META_APP_ID=<META_APP_ID>
META_APP_SECRET=<META_APP_SECRET>                    # verifies X-Hub-Signature-256 on every webhook POST (§5)
META_WEBHOOK_VERIFY_TOKEN=<CHOOSE_A_VERIFY_TOKEN>    # echoed back during the webhook subscription handshake
META_GRAPH_API_VERSION=<GRAPH_API_VERSION>           # e.g. v21.0 — pin the Graph API version
WHATSAPP_ACCESS_TOKEN=<WHATSAPP_PERMANENT_ACCESS_TOKEN>

# WhatsApp number identifiers — maps to tenants.waba_id / phone_number_id (§4) — NEEDS INPUT
WHATSAPP_BUSINESS_ACCOUNT_ID=<WABA_ID>
WHATSAPP_PHONE_NUMBER_ID=<PHONE_NUMBER_ID>           # Meta's numeric ID for the number, not the number itself
WHATSAPP_BUSINESS_NUMBER_E164=<+9665XXXXXXXX>        # the watched business number, E.164 format
CONTROL_CHAT_PHONE_E164=<+9665XXXXXXXX>              # operator number that receives control-chat pings (§10)

# ─────────────────────────────────────────────────────────────────────────────
# LLM classifier model IDs — tiering (§8 / D8-a) — NEEDS INPUT
# Pin exact model IDs here, not in code. First pass runs on the cheap tier; the
# message+history re-run on the escalation model when confidence.overall < threshold.
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
OPENAI_API_KEY=<OPENAI_API_KEY>

CLASSIFIER_MODEL_FIRST_PASS=<ANTHROPIC_MODEL_ID>     # cheap/fast tier (v1.2: "Haiku first")
CLASSIFIER_MODEL_ESCALATION=<ANTHROPIC_MODEL_ID>     # larger model on escalation (Sonnet / Opus)
CLASSIFIER_MODEL_FALLBACK=<OPENAI_MODEL_ID>          # cross-provider peer fallback (OpenAI)
CLASSIFIER_CONFIDENCE_ESCALATION_THRESHOLD=0.85

# Self-hosted / regulated tier — vLLM-served Qwen (Phase 5, §8) — NEEDS INPUT
SELF_HOSTED_LLM_BASE_URL=<VLLM_OPENAI_COMPATIBLE_URL>
SELF_HOSTED_LLM_MODEL=<QWEN_MODEL_ID>

# Media pipeline ASR / vision — transcription (§6 / D3-a) — NEEDS INPUT
ASR_PROVIDER=<whisper-api | faster-whisper>
ASR_MODEL=<ASR_MODEL_ID>
